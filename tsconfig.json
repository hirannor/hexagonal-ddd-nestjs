{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "baseUrl": "src",
    "paths": {
      "@domain/*": ["domain/*"],
      "@application/*": ["application/*"],
      "@infrastructure/*": ["infrastructure/*"],
      "@adapter/*": ["adapter/*"]
    },
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictNullChecks": true,
    "skipLibCheck": true
  }
}